#include <bits/stdc++.h>
using namespace std;
#define _ ios_base::sync_with_stdio(false); cin.tie(nullptr);
#define endl '\n'
#define pb push_back

int main() {
	_ 
	int n;
	vector<int> f;
	vector<int> s;
	for(int i = 0; i<5; i++) {
	    cin >> n;
	    f.pb(n);
	}
	for(int i = 0; i<5; i++) {
	    cin >> n;
	    s.pb(n);
	}
	
	for(int j = 0; j<f.size(); j++) {
	    if(f[j] == s[j]) {
	        cout << "N" << endl;
	        return 0;
	    }
	}
	cout << "Y" << endl;
	return 0;
}
